{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":rebaseStalePrs",
    ":semanticCommits",
    ":semanticCommitScope(deps)",
    "helpers:pinGitHubActionDigests"
  ],
  "configMigration": true,
  "automerge": true,
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)PKGBUILD$/"
      ],
      "matchStrings": [
        "pkgver=(?<currentValue>.*) # renovate: datasource=(?<datasource>.*) depName=(?<depName>.*)"
      ]
    }
  ],
  "packageRules": [
    {
      "matchDepNames": [
        "ggml-org/llama.cpp"
      ],
      "versioning": "regex:^b(?<major>\\d+)$",
      "allowedVersions": "/^b\\d+$/"
    }
  ]
}