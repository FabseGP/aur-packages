{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":rebaseStalePrs",
    ":semanticCommits",
    ":semanticCommitScope(deps)",
    "helpers:pinGitHubActionDigests"
  ],
  "configMigration": true,
  "automerge": true,
  "rebaseWhen": "conflicted",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)PKGBUILD$/"
      ],
      "matchStrings": [
        "pkgver=(?<currentValue>.*) # renovate: datasource=(?<datasource>.*) depName=(?<depName>.*)"
      ]
    }
  ],
  "packageRules": [
    {
      "matchDepNames": [
        "ggml-org/llama.cpp"
      ],
      "versioning": "regex:^b(?<major>\\d+)$",
      "allowedVersions": "/^b\\d+$/",
      "minimumReleaseAge": "90 minutes",
      "internalChecksFilter": "strict"
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "docker.io/library/archlinux"
      ],
      "versioning": "regex:^base-devel-(?<major>\\d{4})(?<minor>\\d{2})(?<patch>\\d{2})\\.(?<build>\\d+)\\.(?<revision>\\d+)$"
    }
  ],
  "ignorePaths": [
    "llama.cpp-cuda/PKGBUILD"
  ]
}