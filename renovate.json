{
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)PKGBUILD$/"
      ],
      "matchStrings": [
        "pkgver=(?<currentValue>.*) # renovate: datasource=(?<datasource>.*) depName=(?<depName>.*)"
      ]
    }
  ],
  "packageRules": [
    {
      "matchDepNames": [
        "ggml-org/llama.cpp"
      ],
      "versioning": "regex:^(?<major>b)(?<patch>\\d+)$",
      "extractVersion": "^b(?<version>\\d+)$"
    }
  ]
}